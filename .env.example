# API keys (required for full functionality)
VOYAGE_API_KEY=
COHERE_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Optional: override Gemini model IDs (defaults: gemini-2.5-flash in config/models.yaml)
# Lower cost:
# GEMINI_VISION_MODEL=gemini-2.5-flash-lite
# GEMINI_GENERATION_MODEL=gemini-2.5-flash-lite

# Parallel ingestion (1–32)
# INGESTION_WORKERS=4
# BENCHMARK_WORKERS=4   # concurrent /benchmark/run and /benchmark/analyze retrievals
# UI → API wait for benchmark generate/eval/analyze (seconds, default 28800 = 8h)
# BENCHMARK_HTTP_TIMEOUT=28800

# Logging: DEBUG, INFO, WARNING
# LOG_LEVEL=INFO

# QDRANT_URL=http://localhost:6333
# REDIS_URL=redis://localhost:6379/0
# ADMIN_TOKEN=changeme
