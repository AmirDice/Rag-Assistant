# Streamlit Community Cloud secrets for the UI.
# Copy to .streamlit/secrets.toml locally, OR paste into:
#   Streamlit Community Cloud → your app → Settings → Secrets.
#
# Streamlit exposes top-level string secrets as environment variables, so the UI
# reads these via os.getenv (no code change needed).

# Base URL of the FastAPI backend on Render.
API_URL = "https://your-backend.onrender.com"

# Must match the backend's ADMIN_TOKEN (used by the admin UI pages: glossary, settings).
ADMIN_TOKEN = "change-me-to-match-backend"
